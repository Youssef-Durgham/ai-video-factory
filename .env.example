# ═══════════════════════════════════════════
# AI Video Factory — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── YouTube API ──────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Required for: trend research, video upload, analytics
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_SECRET=config/youtube_client_secret.json

# ─── Telegram Bot ─────────────────────────
# Get from: @BotFather on Telegram
# Required for: notifications, manual review, topic selection
TELEGRAM_BOT_TOKEN=your_bot_token
# Your personal chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id

# ─── ElevenLabs (Optional Fallback) ──────
# Get from: https://elevenlabs.io/
# Used as fallback when Fish Audio S2 Pro fails
ELEVENLABS_API_KEY=your_elevenlabs_key

# ─── Ollama (Local LLM) ──────────────────
# Default: http://localhost:11434
# Runs Qwen 3.5 for script writing, QA, compliance
OLLAMA_HOST=http://localhost:11434
# Unload models immediately after use (single GPU)
OLLAMA_KEEP_ALIVE=0
# Single GPU = one request at a time
OLLAMA_NUM_PARALLEL=1
# Never load more than one model (24GB VRAM limit)
OLLAMA_MAX_LOADED_MODELS=1

# ─── ComfyUI (Image/Video Generation) ────
# Default: http://localhost:8188
# Runs FLUX (images) and LTX-2.3 (video)
COMFYUI_HOST=http://localhost:8188
